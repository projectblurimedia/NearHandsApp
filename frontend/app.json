{
  "expo": {
    "name": "NearHands",
    "slug": "nearhands",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/brand/Logo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/brand/Logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1D9BF0"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/Logo.png",
        "backgroundColor": "#1D9BF0"
      }
    },
    "web": {
      "favicon": "./assets/brand/Logo.png"
    },
    "plugins": [
      "expo-font",
      "expo-splash-screen"
    ]
  }
}
